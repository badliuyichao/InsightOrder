   <tr height="280" style='height:140.00pt;'>
    <td class="xl67" height="280" style='height:140.00pt;' x:str>支持问题</td>
    <td class="xl68" x:str><a href="https://gfjira.yyrd.com/browse/YWLJQ-13260" target="_parent">YWLJQ-13260</a></td>
