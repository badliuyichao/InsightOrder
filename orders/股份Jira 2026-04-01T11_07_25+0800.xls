   <tr height="196" style='height:98.00pt;'>
    <td class="xl67" height="196" style='height:98.00pt;' x:str>支持问题</td>
    <td class="xl68" x:str><a href="https://gfjira.yyrd.com/browse/YWLJQ-11715" target="_parent">YWLJQ-11715</a></td>
